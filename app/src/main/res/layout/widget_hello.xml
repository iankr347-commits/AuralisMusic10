<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_pill_background"
    android:gravity="center_vertical"
    android:padding="6dp">

    <!-- Album Art (Circular) -->
    <ImageView
        android:id="@+id/img_album_art"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="2dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher" />

    <!-- Song Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="6dp"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txt_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="No Song Playing"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_artist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Unknown Artist"
            android:textColor="#B0B0B0"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Control Buttons Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginEnd="6dp"
        android:gravity="center">

        <!-- Skip Previous -->
        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_previous"
            android:scaleType="centerInside"
            android:padding="5dp"
            android:tint="#FFFFFF" />

        <!-- Play/Pause Button (Large Circular) -->
        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_play_button_bg"
            android:src="@drawable/ic_play"
            android:scaleType="centerInside"
            android:padding="11dp" />

        <!-- Skip Next -->
        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_next"
            android:scaleType="centerInside"
            android:padding="5dp"
            android:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Hidden Like Button (for compatibility) -->
    <ImageButton
        android:id="@+id/btn_like"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
</LinearLayout>